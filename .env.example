# DogWare e-mailconfiguratie (Resend)
# Kopieer dit bestand naar .env.local en vul de echte waarden in.
# .env.local staat in .gitignore en wordt NOOIT gecommit.
# LET OP: zet nooit echte keys in dit bestand — dit bestand gaat WEL naar Git.

# API key van https://resend.com/api-keys
RESEND_API_KEY=

# Afzender. Het domein moet geverifieerd zijn in Resend.
# Tijdens testen zonder eigen domein kan: "DogWare <onboarding@resend.dev>"
# (dan kun je alleen naar je eigen Resend-accountadres sturen)
EMAIL_FROM="DogWare <noreply@jouwdomein.nl>"

# Optioneel: reply-to adres voor alle uitgaande mail
EMAIL_REPLY_TO=

# Ontvanger van interne notificaties (demo-aanvragen e.d.)
EMAIL_INTERNAL=

# Alleen nodig om /admin/* in PRODUCTIE te openen (?token=...).
# In development zijn adminpagina's altijd toegankelijk. Kies een lange random string.
EMAIL_TEST_TOKEN=

# Neon Postgres (Vercel Marketplace) — voor het opslaan van leads.
# Zonder deze variabele blijven intakes gewoon per e-mail binnenkomen.
DATABASE_URL=

# UploadThing (uploadthing.com) — voor foto-uploads in de demo-intake.
# Zonder token wordt de uploadstap automatisch verborgen.
UPLOADTHING_TOKEN=

# Basis-URL van de site, voor links in interne mails naar het adminportaal.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Geheime sleutel voor sessies en ondertekende cookies (partnerattributie).
# Genereer met: openssl rand -hex 32
AUTH_SECRET=

# Attributieperiode van het Partnerprogramma in dagen (standaard 30).
ATTRIBUTION_DAYS=30

# Sandbox-testmodus: zolang EMAIL_FROM het proefadres @resend.dev gebruikt,
# worden ALLE mails naar dit adres omgeleid (met de bedoelde ontvanger in het
# onderwerp), zodat de flow werkt zonder eigen domein. Leeg laten of EMAIL_FROM
# op een geverifieerd domein zetten schakelt dit automatisch uit.
EMAIL_SANDBOX_TO=

# Mollie — betalingen (iDEAL, automatische incasso). test_ of live_.
# Webhook-URL is automatisch <NEXT_PUBLIC_SITE_URL>/api/mollie/webhook
MOLLIE_API_KEY=
